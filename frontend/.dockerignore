# WHY THIS WAS CHOSEN:
# Prevents large local directories (like node_modules and .next) from being copied 
# into the Docker build context. This results in much smaller and faster Docker builds.

node_modules
.next
out
.git
.gitignore
.dockerignore
README.md
Dockerfile
.env*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# WHY THIS WAS CHOSEN:
# This file provides a template for backend environment variables required
# by the FastAPI application. Copy this file to '.env' and fill in your actual keys.
# Required variables are validated at startup to fail-fast on misconfigurations.

# Application Environment (development or production)
ENVIRONMENT=development

# Allowed CORS origins (comma-separated list, e.g., http://localhost:3000,https://myportfolio.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Connection (Neon pgvector / local pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# Redis Cache Connection (Upstash Redis / local Redis)
REDIS_URL=redis://localhost:6379

# Embedding Configuration
EMBEDDING_PROVIDER=azure_openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_CACHE_TTL_SECONDS=604800

# Azure OpenAI Credentials (Required if EMBEDDING_PROVIDER=azure_openai)
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Google Gemini API Key (Required for LLM generator, grader, rewriter, and attributor)
GEMINI_API_KEY=your-gemini-api-key-here

# LLM Providers and Models
GENERATOR_PROVIDER=gemini
GEMINI_MODEL_NAME=gemini-3.1-flash-lite

GRADER_PROVIDER=gemini
MODEL_GRADER=gemini-3.1-flash-lite
GRADER_MIN_CHUNKS=3

ENABLE_QUERY_REWRITER=false
REWRITER_PROVIDER=gemini
MODEL_REWRITER=gemini-3.1-flash-lite

ATTRIBUTOR_PROVIDER=gemini
MODEL_ATTRIBUTOR=gemini-3.1-flash-lite

# GitHub API (For ingestion pipeline, optional but recommended to avoid rate limits)
GITHUB_TOKEN=your-github-personal-access-token-here

# API Rate Limiting Configuration
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Cache Expiration Settings
CACHE_TTL_SECONDS=86400
PROMPT_VERSION=v1.0
